{
  "name": "hotel-management-backend",
  "version": "1.0.0",
  "description": "Jarvis Unified Backend — Multi-platform backend for SaaS, ERP, POS, HR, CRM, Ecommerce, Trading, Education, Marketing, SME & more",
  "main": "Server.js",
  "scripts": {
    "start": "node Server.js",
    "dev": "nodemon Server.js",
    "lint": "eslint src/ --ext .js",
    "test": "jest --testPathPattern=src/__tests__ --forceExit --testTimeout=30000",
    "test:ci": "jest --testPathPattern=src/__tests__ --forceExit --ci --testTimeout=30000 --reporters=default --reporters=jest-junit",
    "test:watch": "jest --testPathPattern=src/__tests__ --watch",
    "seed": "node src/scripts/seedAllModules.js",
    "db:init": "node src/scripts/seedAllModules.js",
    "platform:check": "node -e \"const a=require('./src/app');console.log('✓ All platforms loaded');process.exit(0)\""
  },
  "jest": {
    "testTimeout": 30000
  },
  "jest-junit": {
    "outputDirectory": "./reports/junit",
    "outputName": "junit.xml"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.0.0",
    "mongoose": "^8.3.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.11",
    "pdfkit": "^0.15.0",
    "socket.io": "^4.8.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  }
}
